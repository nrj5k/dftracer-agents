     return global*(static_cast<double>(sp->g->cvac) * static_cast<double>(sp->g->cvac));
 }
+
+// Local-only (no MPI reduction) variant of energy_p_kokkos, used by
+// dump_energies to coalesce all species' energy reductions into a single
+// mp_allsum_d call instead of one per species. Scaling by cvac^2 is applied
+// per-species before the caller sums across species, which is equivalent
+// to applying it after (cvac is the same grid constant for every species),
+// so this produces bit-identical physics to calling energy_p_kokkos per
+// species and summing the globally-reduced results.
+double
+energy_p_local(const species_t* RESTRICT sp,
+               const interpolator_array_t* RESTRICT ia) {
+    if(!sp || !ia || sp->g != ia->g) ERROR(("Bad args"));
+
+    float qdt_2mc = (sp->q*sp->g->dt)/(2*sp->m*sp->g->cvac);
+
+    double local = energy_p_kernel(ia->k_i_d, sp->k_p_d, sp->k_p_i_d, qdt_2mc, sp->m, sp->np);
+    Kokkos::fence();
+
+    return local*(static_cast<double>(sp->g->cvac) * static_cast<double>(sp->g->cvac));
+}
