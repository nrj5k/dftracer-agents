+    def _write_to_disk(state_dict, last_path, best_path, is_best,
+                       hardlink_best=False, stage_dir=None):
+        with DFTracerFn("checkpointing", name="_write_to_disk"):
+            """Worker function to perform actual disk I/O."""
+            # Q2: serialize to node-local flash first, then move to the PFS. A 256 MB
+            # torch.save to Lustre takes ~496 ms (~517 MB/s from one rank) and lands on
+            # the critical path every epoch; local flash is far faster and the move is
+            # a streaming copy off the training thread.
+            target = Path(stage_dir) / last_path.name if stage_dir else last_path
+
+            # Always serialize to a temp path and rename into place. rename() is atomic
+            # and yields a FRESH inode each epoch, which is what makes the 'best'
+            # hardlink below safe: torch.save truncates in place, so a hardlinked best
+            # would otherwise be corrupted by the next epoch's write.
+            tmp = target.with_suffix(target.suffix + ".tmp")
+            try:
+                torch.save(state_dict, tmp)
+                os.replace(tmp, target)
+                if stage_dir:
+                    shutil.move(str(target), str(last_path))
+            except Exception as e:
+                print("Saving checkpoint failed. Continuing...")
+                print(e)
+
+            if is_best:
+                # Q1: hardlink instead of copying 256 MB again. On the epochs where val
+                # loss improves (102/960 in a reference run) shutil.copyfile added a
+                # second full-size write -- 25.5 GB of duplicate I/O per run.
+                if hardlink_best and last_path.exists():
+                    try:
+                        if best_path.exists():
+                            best_path.unlink()
+                        os.link(last_path, best_path)
+                        return
+                    except OSError:
+                        pass  # cross-device or unsupported -> fall back to copy
+                if last_path.exists():
+                    shutil.copyfile(last_path, best_path)
+                else:
+                    try:
+                        torch.save(state_dict, best_path)
+                    except Exception as e:
+                        print("Saving checkpoint failed. Continuing...")
+                        print(e)
 
