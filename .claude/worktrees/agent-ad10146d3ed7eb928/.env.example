# ===== LLM endpoint — OpenAI-compatible =====
# Option A: set these directly
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Option B: LLNL LIVAI (start_agent.sh maps these to OPENAI_* automatically)
LIVAI_BASE_URL=https://livai-api.llnl.gov/v1
LIVAI_MODEL=gpt-4o
LIVAI_API_KEY=

# ===== DFTracer defaults =====
DFTRACER_ENABLE=1
DFTRACER_LOG_FILE=./traces/dftrace
DFTRACER_DATA_DIR=$PWD
