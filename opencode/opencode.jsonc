{
  "mcp": {
    "dftracer": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/llnl/dftracer-agents",
        "dftracer-mcp-server"
      ],
      "enabled": true,
      "env": {}
    }
  },
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "gemma4:31b-cloud",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        // "baseURL": "http://[::1]:11434/v1",
        "baseURL": "http://127.0.0.1:11434/v1",
      },
      "models": {
        "gemma4:31b-cloud": {
          "name": "gemma4",
        },
        "devstral-2:123b-cloud": {
          "name": "devstral",
        },
        "ministral-3:14b-cloud": {
          "name": "Ministral3",
        },
        "orchestrator": {
          "name": "gemma4:31b-cloud",
        },
        "planner": {
          "name": "gemma4:31b-cloud",
        },
      },
    },
  },
}
