  // Model levels are resolved from:
  //   src/dftracer_agents/.agents/workspace/models.yaml
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "dftracer": {
      "type": "remote",
      "url": "http://127.0.0.1:5000/mcp",
      "enabled": true
    }
  }
}
